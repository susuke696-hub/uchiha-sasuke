rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { 
      return request.resource.data; 
    }
    function existing() { 
      return resource.data; 
    }
    function isSignedIn() { 
      return request.auth != null; 
    }

    // Validation
    function isValidUser(data) {
      return data.keys().hasOnly(['email', 'name', 'createdAt'])
        && data.get('email', '') is string
        && (data.get('name', '') is string || !('name' in data))
        && (data.get('createdAt', 0) is timestamp || data.get('createdAt', 0) is number || !('createdAt' in data));
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if isSignedIn() && resource.data.email == request.auth.token.email;
      
      allow create: if isSignedIn() 
        && isValidId(userId)
        && request.auth.uid == userId
        && isValidUser(incoming());
        
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['name']);
        
      allow delete: if false;
    }
  }
}
